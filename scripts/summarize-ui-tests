#!/usr/bin/env python3

from __future__ import annotations

import os
import sys
import xml.etree.ElementTree as ET
from pathlib import Path


def local_name(tag: str) -> str:
    return tag.split('}', 1)[-1]


def format_summary(lines: list[str]) -> str:
    return '\n'.join(lines) + '\n'


def summarize(xml_path: Path) -> list[str]:
    root = ET.parse(xml_path).getroot()

    failed = []
    total = 0

    for testcase in root.iter():
        if local_name(testcase.tag) != 'testcase':
            continue

        total += 1
        classname = testcase.attrib.get('classname', '')
        name = testcase.attrib.get('name', '<unknown test>')
        problems = [
            child
            for child in list(testcase)
            if local_name(child.tag) in {'failure', 'error'}
        ]
        if not problems:
            continue

        details = []
        for problem in problems:
            message = (problem.attrib.get('message') or '').strip()
            text = (problem.text or '').strip()

            block_parts = [part for part in (message, text) if part]
            details.append('\n\n'.join(block_parts) or '(no stack trace text provided)')

        failed.append(
            {
                'classname': classname,
                'name': name,
                'details': '\n\n'.join(details),
            }
        )

    lines = ['# Test Summary', '']

    if not failed:
        lines.append(f'All {total} test case(s) passed.')
        return lines

    lines.append(f'## Failed tests ({len(failed)}/{total})')
    lines.append('')

    for test in failed:
        full_name = (
            f"{test['classname']} > {test['name']}"
            if test['classname']
            else test['name']
        )
        lines.append(f'### `{full_name}`')
        lines.append('')
        lines.append('```text')
        lines.append(test['details'])
        lines.append('```')
        lines.append('')

    return lines


def main(argv: list[str]) -> int:
    xml_paths = argv[1:]
    if len(xml_paths) != 1:
        lines = [
            '# Test Summary',
            '',
            f'Expected exactly one XML report path argument, found {len(xml_paths)}.',
        ]
        if xml_paths:
            lines.append('')
            lines.append('Provided arguments:')
            lines.append('')
            lines.extend(f'- `{xml_path}`' for xml_path in xml_paths)
        sys.stdout.write(format_summary(lines))
        return 0

    xml_path = Path(xml_paths[0])
    try:
        sys.stdout.write(format_summary(summarize(xml_path)))
    except ET.ParseError as exc:
        sys.stdout.write(
            format_summary([
                '# UI Tests Summary',
                '',
                f'Could not parse `{xml_path}`: {exc}',
            ])
        )
        return 0

    return 0


if __name__ == '__main__':
    raise SystemExit(main(sys.argv))
